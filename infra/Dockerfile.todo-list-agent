# ── Stage 1: Build MCP server (Node.js) ──────────────────────
FROM node:22-slim AS mcp-builder

# better-sqlite3 needs python3, make, g++ for native addon compilation
RUN apt-get update && apt-get install -y --no-install-recommends python3 make g++ && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy dependency manifest first (for layer caching)
COPY agents/todo_list/mcp_tool/server/package.json agents/todo_list/mcp_tool/server/yarn.lock* ./
RUN npm install

# Copy source and compile TypeScript
COPY agents/todo_list/mcp_tool/server/src/ ./src/
COPY agents/todo_list/mcp_tool/server/tsconfig.json ./
RUN npm run build

# ── Stage 2: Python runtime ─────────────────────────────────
FROM python:3.12-slim-bookworm

# Install uv and curl for healthcheck
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# Copy Node.js binary from build stage (no NodeSource install needed)
COPY --from=mcp-builder /usr/local/bin/node /usr/local/bin/node

WORKDIR /app

# Install Python dependencies (cached unless pyproject.toml/uv.lock change)
COPY agents/todo_list/pyproject.toml agents/todo_list/uv.lock ./
RUN uv sync --no-dev --no-install-project

# Copy application code
COPY agents/todo_list/*.py agents/todo_list/start.sh* ./
COPY agents/todo_list/mcp_tool/client/ ./mcp_tool/client/
COPY agents/todo_list/pyproject.toml agents/todo_list/uv.lock ./

# Upgrade shinox-agent-sdk to latest and install the project
RUN uv lock --upgrade-package shinox-agent-sdk && uv sync --no-dev

# Copy pre-built MCP server from stage 1 (no make/g++/npm needed here)
COPY --from=mcp-builder /build/dist/ /app/mcp_server/dist/
COPY --from=mcp-builder /build/node_modules/ /app/mcp_server/node_modules/

ENV PATH="/app/.venv/bin:$PATH"
ENV MCP_SERVER_PATH="/app/mcp_server/dist/index.js"

RUN printf '#!/bin/sh\nnode /app/mcp_server/dist/dashboard.js &\nexec faststream run main:app\n' > /app/start.sh && \
    chmod +x /app/start.sh

EXPOSE 3456

CMD ["/app/start.sh"]
